# --- LiveKit ---
# From your LiveKit Cloud project (cloud.livekit.io) or self-hosted server config.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Google Cloud (Speech-to-Text + Text-to-Speech) ---
# Path to a service account JSON key with the Cloud Speech-to-Text API and
# Cloud Text-to-Speech API enabled.
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# --- Gemini (LLM / dialog + tool-calling) ---
# From Google AI Studio: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# --- Token server (used by the web client to join the LiveKit room) ---
TOKEN_SERVER_PORT=8080
